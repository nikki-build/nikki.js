{
  "name": "nikki.js",
  "version": "0.3.4",
  "description": "nikki.build JavaScript browser client library.",
  "author": "dev.nikki.build@gmail.com",
   "main": "./dist/nikki.js",
  "module": "./dist/nikki.mjs",
  "types": "./dist/nikki.d.ts",
  "exports": {
    ".": {
      "types": "./dist/nikki.d.ts",
      "import": "./dist/nikki.mjs",
      "require": "./dist/nikki.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "keywords": [
    "javascript",
    "browser",
    "client",
    "nikki",
    "realtime",
    "diy",
    "prototyping"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nikki-build/nikki.js.git"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/nikki-build/nikki.js/issues"
  },
  "homepage": "https://github.com/nikki-build/nikki.js#readme",
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
